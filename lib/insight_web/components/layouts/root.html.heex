<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta name="description" content="Insight — AI 驱动的 HackerNews 智能阅读器" />
    <%!-- 引入 Inter 字体，提升排版质感 --%>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <.live_title default="Insight" suffix=" · 智能阅读">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <%!-- 主题切换脚本：在页面加载前读取 localStorage 设置主题，避免闪烁 --%>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body class="font-sans antialiased">
    <%!-- 顶部导航栏：根据登录状态显示不同菜单 --%>
    <ul class="menu menu-horizontal w-full relative z-10 flex items-center gap-4 px-4 sm:px-6 lg:px-8">
      <li class="mr-auto">
        <a href="/" class="flex items-center gap-2">
          <span class="text-xl font-bold tracking-tight">Insight</span>
          <span class="text-xs opacity-50 font-medium">智能阅读</span>
        </a>
      </li>
      <%= if @current_scope do %>
        <li class="text-sm opacity-70">
          {@current_scope.user.email}
        </li>
        <li>
          <.link href={~p"/daily-summaries"} class="text-sm font-medium hover:opacity-80 transition-opacity">
            个人日报
          </.link>
        </li>
        <li>
          <.link href={~p"/radar"} class="text-sm font-medium hover:opacity-80 transition-opacity">
            数据雷达
          </.link>
        </li>
        <li>
          <.link href={~p"/tags"} class="text-sm font-medium hover:opacity-80 transition-opacity">
            标签管理
          </.link>
        </li>
        <li>
          <.link href={~p"/blocked"} class="text-sm font-medium hover:opacity-80 transition-opacity">
            屏蔽管理
          </.link>
        </li>
        <li>
          <.link href={~p"/users/settings"} class="text-sm font-medium hover:opacity-80 transition-opacity">
            设置
          </.link>
        </li>
        <li>
          <.link href={~p"/users/log-out"} method="delete" class="text-sm font-medium hover:opacity-80 transition-opacity">
            退出登录
          </.link>
        </li>
      <% else %>
        <li>
          <.link href={~p"/users/register"} class="text-sm font-medium hover:opacity-80 transition-opacity">
            注册
          </.link>
        </li>
        <li>
          <.link href={~p"/users/log-in"} class="text-sm font-medium hover:opacity-80 transition-opacity">
            登录
          </.link>
        </li>
      <% end %>
      <li>
        <a href="https://github.com/pdsong/insight" target="_blank" rel="noopener noreferrer"
           class="opacity-60 hover:opacity-100 transition-opacity" title="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      </li>
    </ul>
    {@inner_content}
  </body>
</html>
